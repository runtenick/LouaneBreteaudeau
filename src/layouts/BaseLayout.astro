---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import { routeOrder } from '../navigation';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Portfolio d'architecture de Louane Breteaudeau.",
} = Astro.props;

const pageTitle =
	title === 'Accueil'
		? "Louane Breteaudeau - Portfolio d'architecture"
		: `${title} - Louane Breteaudeau`;

const basePath = import.meta.env.BASE_URL;
const normalizedBase = basePath === '/' ? '' : basePath.replace(/\/$/, '');
const withBase = (path: string) => {
	if (!normalizedBase) return path;
	return `${normalizedBase}${path}`;
};
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="icon" href={withBase('/favicon.ico')} />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<ClientRouter />
		<script is:inline define:vars={{ routeOrder, basePath }}>
			const siteBase = basePath === '/' ? '' : basePath.replace(/\/$/, '');

			const stripBase = (pathname) => {
				if (!siteBase) return pathname;
				if (pathname === siteBase) return '/';
				if (pathname.startsWith(`${siteBase}/`)) {
					return pathname.slice(siteBase.length) || '/';
				}

				return pathname;
			};

			const normalizeRoute = (pathname) => {
				const strippedPathname = stripBase(pathname);
				if (strippedPathname === '/') return strippedPathname;
				return strippedPathname.endsWith('/') ? strippedPathname : `${strippedPathname}/`;
			};

			const getRouteIndex = (value) => {
				const url = value instanceof URL ? value : new URL(value, window.location.href);
				return routeOrder.indexOf(normalizeRoute(url.pathname));
			};

			const getRouteDirection = (from, to) => {
				const fromIndex = getRouteIndex(from);
				const toIndex = getRouteIndex(to);

				if (fromIndex === -1 || toIndex === -1 || fromIndex === toIndex) {
					return 'forward';
				}

				return toIndex > fromIndex ? 'forward' : 'back';
			};

			document.addEventListener('astro:before-preparation', (event) => {
				const direction = getRouteDirection(event.from, event.to);
				window.__portfolioRouteDirection = direction;
				document.documentElement.dataset.routeDirection = direction;
			});

			document.addEventListener('astro:before-swap', (event) => {
				const direction = window.__portfolioRouteDirection ?? getRouteDirection(event.from, event.to);
				document.documentElement.dataset.routeDirection = direction;
				event.newDocument.documentElement.dataset.routeDirection = direction;
			});

			document.addEventListener('astro:page-load', () => {
				window.setTimeout(() => {
					document.documentElement.removeAttribute('data-route-direction');
					window.__portfolioRouteDirection = undefined;
				}, 700);
			});
		</script>
	</head>
	<body class="min-h-screen bg-stone-50 text-neutral-950 antialiased">
		<Header currentPath={Astro.url.pathname} />
		<main data-page-transition class="min-h-screen pt-28 sm:pt-24">
			<slot />
		</main>
	</body>
</html>
