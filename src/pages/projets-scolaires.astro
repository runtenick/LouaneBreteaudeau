---
import ProjectIndex from '../components/ProjectIndex.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { ImageMetadata } from 'astro';

const pfeB3Modules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/projects/pfe-b3/*.{png,svg}',
	{ eager: true },
);

const workshopCeramisteModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/projects/ws-ceramique/*.png',
	{ eager: true },
);

const colocationCampagneModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/projects/colocation-a-la-campagne/*.png',
	{ eager: true },
);

const jaudeModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/projects/jaude/*.png',
	{ eager: true },
);

const joModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/projects/jo/*.{png,jpg,jpeg}',
	{ eager: true },
);

const joVideoModules = import.meta.glob<string>('../assets/projects/jo/*.mp4', {
	eager: true,
	query: '?url',
	import: 'default',
});

const pfeB3Assets = Object.entries(pfeB3Modules)
	.sort(([left], [right]) => (left < right ? -1 : left > right ? 1 : 0))
	.map(([path, module]) => ({ path, image: module.default }));

const pfeB3Cover = pfeB3Assets.find(({ path }) => path.includes('00-Image de presentation'))?.image;
const pfeB3TitleBackground = pfeB3Assets.find(({ path }) => path.includes('00-cadmapper-issoire'))?.image;
const pfeB3Gallery = pfeB3Assets.filter(({ path }) => !path.split('/').pop()?.startsWith('00-'));

type NumberedImagePanel =
	| { type: 'image'; image: ImageMetadata; rotate?: 90; fit?: 'cover' }
	| { type: 'image-stack'; images: ImageMetadata[]; rotate?: 90; fit?: 'cover' };

const createNumberedPanels = (
	assets: Array<{ path: string; image: ImageMetadata }>,
	rotatedGroups: readonly string[] = [],
	coverGroups: readonly string[] = [],
): NumberedImagePanel[] => {
	const groups = new Map<string, ImageMetadata[]>();

	assets.forEach(({ path, image }) => {
		const filename = path.split('/').pop() ?? '';
		const number = filename.match(/^(\d+)-/)?.[1] ?? filename;
		const group = groups.get(number) ?? [];
		group.push(image);
		groups.set(number, group);
	});

	return Array.from(groups.entries()).map(([number, images]) =>
		images.length > 1
			? {
					type: 'image-stack',
					images,
					rotate: rotatedGroups.includes(number) ? 90 : undefined,
					fit: coverGroups.includes(number) ? 'cover' : undefined,
				}
			: {
					type: 'image',
					image: images[0],
					rotate: rotatedGroups.includes(number) ? 90 : undefined,
					fit: coverGroups.includes(number) ? 'cover' : undefined,
				},
	);
};

const pfeB3Panels = createNumberedPanels(pfeB3Gallery, ['03']);

const workshopCeramisteAssets = Object.entries(workshopCeramisteModules)
	.sort(([left], [right]) => (left < right ? -1 : left > right ? 1 : 0))
	.map(([path, module]) => ({ path, image: module.default }));

const workshopCeramisteCover = workshopCeramisteAssets.find(({ path }) =>
	path.includes('00-') && path.includes('boutique'),
)?.image;
const workshopCeramisteTitleBackground = workshopCeramisteAssets.find(({ path }) =>
	path.includes('00-cadmapper-clermont-ferrand'),
)?.image;
const workshopCeramisteGallery = workshopCeramisteAssets.filter(
	({ path }) => !path.split('/').pop()?.startsWith('00-'),
);
const workshopCeramistePanels = createNumberedPanels(workshopCeramisteGallery);

const colocationCampagneAssets = Object.entries(colocationCampagneModules)
	.sort(([left], [right]) => (left < right ? -1 : left > right ? 1 : 0))
	.map(([path, module]) => ({ path, image: module.default }));

const colocationCampagneCover = colocationCampagneAssets[0]?.image;
const colocationCampagnePanels = createNumberedPanels(colocationCampagneAssets.slice(1));

const jaudeAssets = Object.entries(jaudeModules)
	.sort(([left], [right]) => (left < right ? -1 : left > right ? 1 : 0))
	.map(([path, module]) => ({ path, image: module.default }));

const jaudeCover = jaudeAssets.find(({ path }) => path.includes('00-isometrie'))?.image;
const jaudeTitleBackground = jaudeAssets.find(({ path }) =>
	path.includes('00-cadmapper-clermont-ferrand'),
)?.image;
const jaudeGallery = jaudeAssets.filter(
	({ path }) => !path.split('/').pop()?.startsWith('00-'),
);
const jaudePanels = createNumberedPanels(jaudeGallery, [], ['06', '07', '08']);

const joAssets = Object.entries(joModules)
	.sort(([left], [right]) => (left < right ? -1 : left > right ? 1 : 0))
	.map(([path, module]) => ({ path, image: module.default }));

const joCover = joAssets.find(({ path }) => path.split('/').pop()?.startsWith('00-'))?.image;
const joGallery = joAssets.filter(
	({ path }) => !path.split('/').pop()?.startsWith('00-'),
);
const joVideo = Object.entries(joVideoModules).sort(([left], [right]) =>
	left < right ? -1 : left > right ? 1 : 0,
)[0]?.[1];
const joPanels = [
	...createNumberedPanels(joGallery),
	...(joVideo ? [{ type: 'video' as const, src: joVideo }] : []),
];

const projects = [
	{
		title: 'PFE B3',
		cover: pfeB3Cover,
		titleBackground: pfeB3TitleBackground,
		panels: pfeB3Panels,
	},
	{
		title: 'Workshop céramiste',
		cover: workshopCeramisteCover,
		titleBackground: workshopCeramisteTitleBackground,
		panels: workshopCeramistePanels,
	},
	{
		title: 'Colocation à la campagne',
		cover: colocationCampagneCover,
		panels: colocationCampagnePanels,
	},
	{
		title: 'Jaude',
		cover: jaudeCover,
		coverFit: 'contained',
		titleBackground: jaudeTitleBackground,
		panels: jaudePanels,
	},
	{
		title: 'JO',
		cover: joCover,
		panels: joPanels,
	},
] as const;
---

<BaseLayout title="Projets scolaires">
	<ProjectIndex
		title="Projets scolaires"
		intro="Une sélection de recherches académiques autour de l'habiter, des seuils, des espaces publics et des équipements de proximité."
		idPrefix="projets-scolaires"
		projects={projects}
	/>
</BaseLayout>
