---
import ProjectIndex from '../components/ProjectIndex.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { ImageMetadata } from 'astro';

const pfeB3Modules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/projects/pfe-b3/*.{png,svg}',
	{ eager: true },
);

const pfeB3Assets = Object.entries(pfeB3Modules)
	.sort(([left], [right]) => (left < right ? -1 : left > right ? 1 : 0))
	.map(([path, module]) => ({ path, image: module.default }));

const pfeB3Cover = pfeB3Assets.find(({ path }) => path.includes('00-Image de presentation'))?.image;
const pfeB3TitleBackground = pfeB3Assets.find(({ path }) => path.includes('00-cadmapper-issoire'))?.image;
const pfeB3Gallery = pfeB3Assets.filter(({ path }) => !path.split('/').pop()?.startsWith('00-'));

type PFEPanel =
	| { type: 'image'; image: ImageMetadata }
	| { type: 'image-stack'; images: ImageMetadata[] };

const pfeB3Groups = new Map<string, ImageMetadata[]>();

pfeB3Gallery.forEach(({ path, image }) => {
	const filename = path.split('/').pop() ?? '';
	const number = filename.match(/^(\d+)-/)?.[1] ?? filename;
	const group = pfeB3Groups.get(number) ?? [];
	group.push(image);
	pfeB3Groups.set(number, group);
});

const pfeB3Panels: PFEPanel[] = Array.from(pfeB3Groups.values()).map((images) =>
	images.length > 1
		? { type: 'image-stack', images }
		: { type: 'image', image: images[0] },
);

const projects = [
	{
		title: 'PFE B3',
		cover: pfeB3Cover,
		titleBackground: pfeB3TitleBackground,
		panels: pfeB3Panels,
	},
	{
		title: 'Maison-patio',
		description:
			"Habitat compact organisé autour d'un vide central, pensé comme une pièce extérieure pour la lumière, les circulations et les usages communs.",
		meta: 'Atelier L2 - logement',
		panels: [
			{ type: 'image', legend: 'Axonométrie générale', tone: 'sage' },
			{
				type: 'text',
				label: 'Recherche',
				title: 'La cour comme pièce principale',
				body:
					"Les espaces domestiques s'ouvrent vers un patio protégé. La distribution devient une promenade courte, lisible, capable de multiplier les vues sans agrandir le volume bâti.",
			},
			{ type: 'image', legend: 'Plan du rez-de-chaussée', tone: 'stone' },
			{ type: 'image', legend: 'Façade intérieure', tone: 'steel' },
		],
	},
	{
		title: 'Bibliothèque de quartier',
		description:
			"Équipement culturel de proximité composé comme une succession de plateaux calmes, depuis l'accueil ouvert jusqu'aux espaces de lecture silencieux.",
		meta: 'Atelier M1 - équipement',
		panels: [
			{ type: 'image', legend: 'Insertion urbaine', tone: 'steel' },
			{ type: 'image', legend: 'Structure et trame', tone: 'stone' },
			{
				type: 'text',
				label: 'Ambiance',
				title: 'Des profondeurs de lecture',
				body:
					'Les plateaux alternent zones traversées et alcôves plus basses. La lumière naturelle guide les déplacements, tandis que le mobilier fixe définit les seuils de concentration.',
			},
			{ type: 'image', legend: 'Vue intérieure', tone: 'clay' },
			{ type: 'image', legend: 'Coupe longitudinale', tone: 'sage' },
		],
	},
] as const;
---

<BaseLayout title="Projets scolaires">
	<ProjectIndex
		title="Projets scolaires"
		intro="Une sélection de recherches académiques autour de l'habiter, des seuils, des espaces publics et des équipements de proximité."
		idPrefix="projets-scolaires"
		projects={projects}
	/>
</BaseLayout>
