---
import type { ImageMetadata } from 'astro';
import ProjectIndex from '../components/ProjectIndex.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

type ImageAsset = { path: string; image: ImageMetadata };

type ImagePanel =
	| { type: 'image'; image: ImageMetadata }
	| { type: 'image-stack'; images: ImageMetadata[] };

const crespoModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/projects/professional/crespo/*.{png,jpg,jpeg}',
	{ eager: true },
);

const jakkelModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/projects/professional/jakkel/*.{png,jpg,jpeg}',
	{ eager: true },
);

const picardModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/projects/professional/picard/*.{png,jpg,jpeg}',
	{ eager: true },
);

const getAssets = (
	modules: Record<string, { default: ImageMetadata }>,
): ImageAsset[] =>
	Object.entries(modules)
		.sort(([left], [right]) => left.localeCompare(right, 'fr', { numeric: true }))
		.map(([path, module]) => ({ path, image: module.default }));

const getFilename = (path: string) => path.split('/').pop() ?? '';

const createGroupedPanels = (
	assets: ImageAsset[],
	getGroup: (filename: string) => string,
): ImagePanel[] => {
	const groups = new Map<string, ImageMetadata[]>();

	assets.forEach(({ path, image }) => {
		const groupName = getGroup(getFilename(path));
		const images = groups.get(groupName) ?? [];
		images.push(image);
		groups.set(groupName, images);
	});

	return Array.from(groups.values()).map((images) =>
		images.length > 1
			? { type: 'image-stack', images }
			: { type: 'image', image: images[0] },
	);
};

const getNumberedGroup = (filename: string) =>
	filename.match(/^(\d+)-/)?.[1] ?? filename;

const crespoAssets = getAssets(crespoModules);
const crespoCover = crespoAssets.find(({ path }) => getFilename(path).startsWith('00-'))?.image;
const crespoGallery = crespoAssets.filter(({ path }) => !getFilename(path).startsWith('00-'));
const crespoPanels = createGroupedPanels(crespoGallery, getNumberedGroup);

const jakkelAssets = getAssets(jakkelModules);
const jakkelCover = jakkelAssets.find(({ path }) => getFilename(path).startsWith('00-'))?.image;
const jakkelGallery = jakkelAssets.filter(({ path }) => !getFilename(path).startsWith('00-'));
const jakkelPanels = createGroupedPanels(jakkelGallery, getNumberedGroup);

const picardAssets = getAssets(picardModules);
const picardCover = picardAssets.find(({ path }) => getFilename(path) === '00.png')?.image;
const picardGallery = picardAssets.filter(({ path }) => getFilename(path) !== '00.png');
const picardPanels = createGroupedPanels(
	picardGallery,
	(filename) => filename.match(/^(V\d+)-/)?.[1] ?? filename,
);

const projects = [
	{
		title: 'Crespo',
		cover: crespoCover,
		panels: crespoPanels,
	},
	{
		title: 'Jakkel',
		cover: jakkelCover,
		panels: jakkelPanels,
	},
	{
		title: 'Picard',
		cover: picardCover,
		panels: picardPanels,
	},
] as const;
---

<BaseLayout title="Projets d'entreprise">
	<ProjectIndex
		title="Projets d'entreprise"
		intro="Une sélection de projets développés en agence, des premières études aux documents de conception."
		idPrefix="projets-entreprise"
		projects={projects}
	/>
</BaseLayout>
