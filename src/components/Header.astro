---
import { headerNavItems } from '../navigation';

interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const normalizedBase = basePath === '/' ? '' : basePath.replace(/\/$/, '');

const withBase = (path: string) => {
	if (!normalizedBase) return path;
	if (path === '/') return `${normalizedBase}/`;
	return `${normalizedBase}${path}`;
};

const stripBase = (path: string) => {
	if (!normalizedBase) return path;
	if (path === normalizedBase) return '/';
	if (path.startsWith(`${normalizedBase}/`)) {
		return path.slice(normalizedBase.length) || '/';
	}

	return path;
};

const normalizePath = (path: string) => {
	if (path === '/') return path;
	return path.endsWith('/') ? path : `${path}/`;
};

const activePath = normalizePath(stripBase(currentPath));
---

<header class="fixed inset-x-0 top-0 z-20 border-b border-neutral-200/80 bg-stone-50/95 backdrop-blur">
	<div class="mx-auto flex max-w-7xl flex-col gap-4 px-5 py-5 sm:flex-row sm:items-start sm:justify-between sm:px-8">
		<a
			href={withBase('/')}
			class="w-fit text-xs font-medium uppercase tracking-[0.24em] text-neutral-950 transition-colors hover:text-neutral-500"
		>
			Louane Breteaudeau
		</a>

		<nav aria-label="Navigation principale">
			<ul class="flex flex-wrap gap-x-5 gap-y-2 text-[0.68rem] font-medium uppercase tracking-[0.18em] sm:justify-end sm:gap-x-7">
				{
					headerNavItems.map((item) => {
						const isActive = activePath === normalizePath(item.href);

						return (
							<li>
								<a
									href={withBase(item.href)}
									aria-current={isActive ? 'page' : undefined}
									class:list={[
										'transition-colors hover:text-neutral-950',
										isActive ? 'text-neutral-950' : 'text-neutral-500',
									]}
								>
									{item.label}
								</a>
							</li>
						);
					})
				}
			</ul>
		</nav>
	</div>
</header>
