---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type ImagePanel = {
	type: 'image';
	image?: ImageMetadata;
	legend?: string;
	tone?: 'stone' | 'sage' | 'clay' | 'steel';
};

type TextPanel = {
	type: 'text';
	label: string;
	title: string;
	body: string;
};

type ImageStackPanel = {
	type: 'image-stack';
	images: readonly ImageMetadata[];
};

type ProjectPanel = ImagePanel | ImageStackPanel | TextPanel;

type Project = {
	title: string;
	description?: string;
	meta?: string;
	cover?: ImageMetadata;
	titleBackground?: ImageMetadata;
	panels: readonly ProjectPanel[];
};

interface Props {
	title: string;
	intro: string;
	projects: readonly Project[];
	idPrefix: string;
}

const { title, intro, projects, idPrefix } = Astro.props;
---

<section class="project-index mx-auto w-full max-w-[1800px]" data-project-index>
	<div class="px-5 pb-10 pt-2 sm:px-8 lg:px-10">
		<div class="max-w-4xl">
			<p class="text-[0.66rem] font-medium uppercase tracking-[0.24em] text-neutral-500">Index</p>
			<h1 class="mt-5 max-w-3xl text-4xl font-light tracking-normal text-neutral-950 sm:text-6xl lg:text-7xl">
				{title}
			</h1>
			<p class="mt-6 max-w-2xl text-base font-light leading-7 text-neutral-500 sm:text-lg sm:leading-8">
				{intro}
			</p>
		</div>
	</div>

	<div class="border-t border-neutral-200">
		{
			projects.map((project, projectIndex) => {
				const isOpen = projectIndex === 0;
				const number = String(projectIndex + 1).padStart(2, '0');
				const panelId = `${idPrefix}-detail-${projectIndex}`;

				return (
					<article class="project-item border-b border-neutral-200" data-project data-open={isOpen ? 'true' : 'false'}>
						<button
							type="button"
							class="project-trigger grid min-h-[34rem] w-full grid-cols-1 text-left transition-colors duration-300 hover:bg-white/50 lg:min-h-[62vh] lg:grid-cols-[minmax(0,1fr)_minmax(19rem,24rem)]"
							aria-controls={panelId}
							aria-expanded={isOpen ? 'true' : 'false'}
						>
							<span
								class={project.cover
									? 'project-cover project-cover-has-image'
									: `project-cover project-cover-${projectIndex % 4}`}
								aria-hidden="true"
							>
								{project.cover && (
									<Image
										src={project.cover}
										alt=""
										widths={[640, 960, 1440, 1920]}
										sizes="(min-width: 1024px) 75vw, 100vw"
										class="project-cover-image"
									/>
								)}
								<span class="project-cover-index">{number}</span>
								{!project.cover && <span class="project-cover-frame"></span>}
							</span>

							<span class={`project-summary flex min-h-72 flex-col justify-between border-t border-neutral-200 px-5 py-6 sm:px-8 lg:min-h-0 lg:border-l lg:border-t-0 lg:px-8 lg:py-9${project.titleBackground ? ' project-summary-has-image' : ''}`}>
								{project.titleBackground && (
									<Image
										src={project.titleBackground}
										alt=""
										class="project-summary-image"
									/>
								)}
								<span class="project-summary-content">
									{project.meta && (
										<span class="text-[0.62rem] font-medium uppercase tracking-[0.22em] text-neutral-400">
											{project.meta}
										</span>
									)}
									<span class="mt-5 block text-3xl font-light leading-none tracking-normal text-neutral-950 sm:text-4xl">
										{project.title}
									</span>
									{project.description && (
										<span class="mt-5 block text-sm font-light leading-6 text-neutral-500">
											{project.description}
										</span>
									)}
								</span>

								<span class="project-state mt-10 h-9 w-9 self-start rounded-full border border-neutral-300 text-center text-2xl font-light leading-8 text-neutral-500 transition-colors duration-300" aria-hidden="true"></span>
							</span>
						</button>

						<div class="project-detail bg-stone-100/60" id={panelId} aria-hidden={isOpen ? 'false' : 'true'}>
							<div class="grid min-w-0 gap-6 px-5 py-6 sm:px-8 lg:grid-cols-[minmax(12rem,19rem)_minmax(0,1fr)] lg:px-10 lg:py-8">
								<aside class="hidden text-neutral-500 lg:block">
									<div class="sticky top-32">
										<p class="text-[0.62rem] font-medium uppercase tracking-[0.22em]">{number}</p>
										<h2 class="mt-5 text-2xl font-light leading-tight text-neutral-950">{project.title}</h2>
										{project.description && <p class="mt-4 text-sm font-light leading-6">{project.description}</p>}
									</div>
								</aside>

								<div class="project-strip min-w-0 overflow-x-auto pb-4">
									<div class="flex w-max gap-4 pr-5 sm:gap-5 lg:pr-10">
										{
											project.panels.map((panel) => {
												if (panel.type === 'text') {
													return (
														<section class="project-text-panel flex min-h-[28rem] w-[78vw] max-w-[30rem] shrink-0 snap-start flex-col justify-between border border-neutral-200 bg-stone-50 p-6 sm:min-h-[34rem] sm:p-8">
															<p class="text-[0.62rem] font-medium uppercase tracking-[0.22em] text-neutral-400">
																{panel.label}
															</p>
															<div>
																<h3 class="text-3xl font-light leading-tight text-neutral-950 sm:text-4xl">
																	{panel.title}
																</h3>
																<p class="mt-6 text-sm font-light leading-7 text-neutral-500">
																	{panel.body}
																</p>
															</div>
																	</section>
																);
															}

															if (panel.type === 'image-stack') {
																return (
																	<figure class="project-slide w-[84vw] max-w-[58rem] shrink-0 snap-start sm:w-[68vw] lg:w-[54vw]">
																		<button
																			type="button"
																			class="project-image-stack"
																			data-image-stack
																			aria-label="Afficher l'image suivante"
																		>
																			{panel.images.map((image, imageIndex) => (
																				<Image
																					src={image}
																					alt=""
																					widths={[480, 768, 1200, 1600]}
																					sizes="(min-width: 1024px) 54vw, 84vw"
																					class="project-stack-image"
																					data-stack-image
																					data-active={imageIndex === 0 ? 'true' : 'false'}
																				/>
																			))}
																			<span class="project-stack-count" data-stack-count>1 / {panel.images.length}</span>
																		</button>
																	</figure>
																);
															}

								return (
									<figure class="project-slide w-[84vw] max-w-[58rem] shrink-0 snap-start sm:w-[68vw] lg:w-[54vw]">
										{panel.image ? (
											<div class="project-image-frame">
												<Image
													src={panel.image}
													alt={panel.legend ?? ''}
													widths={[480, 768, 1200, 1600]}
													sizes="(min-width: 1024px) 54vw, 84vw"
													class="project-image"
												/>
											</div>
										) : (
											<div class={`project-mock-image tone-${panel.tone ?? 'stone'}`} aria-hidden="true">
												<span></span>
											</div>
										)}
										{panel.legend && (
											<figcaption class="mt-3 text-[0.68rem] font-medium uppercase tracking-[0.18em] text-neutral-500">
												{panel.legend}
											</figcaption>
										)}
									</figure>
								);
											})
										}
									</div>
								</div>
							</div>
						</div>
					</article>
				);
			})
		}
	</div>
</section>

<script>
	const setupProjectIndexes = () => {
		document.querySelectorAll('[data-project-index]').forEach((root) => {
			if (!(root instanceof HTMLElement) || root.dataset.projectIndexReady === 'true') {
				return;
			}

			root.dataset.projectIndexReady = 'true';
			const projects = Array.from(root.querySelectorAll('[data-project]'));

			projects.forEach((project) => {
				if (!(project instanceof HTMLElement)) return;

				const trigger = project.querySelector('.project-trigger');
				const detail = project.querySelector('.project-detail');

				if (!(trigger instanceof HTMLButtonElement) || !(detail instanceof HTMLElement)) {
					return;
				}

				trigger.addEventListener('click', () => {
					const shouldOpen = project.dataset.open !== 'true';

					projects.forEach((item) => {
						if (!(item instanceof HTMLElement)) return;

						const itemTrigger = item.querySelector('.project-trigger');
						const itemDetail = item.querySelector('.project-detail');
						const isActive = shouldOpen && item === project;

						item.dataset.open = isActive ? 'true' : 'false';

						if (itemTrigger instanceof HTMLButtonElement) {
							itemTrigger.setAttribute('aria-expanded', String(isActive));
						}

						if (itemDetail instanceof HTMLElement) {
							itemDetail.setAttribute('aria-hidden', String(!isActive));
						}
					});

					if (shouldOpen) {
						window.setTimeout(() => {
							project.scrollIntoView({ block: 'start', behavior: 'smooth' });
						}, 120);
					}
				});
			});

			root.querySelectorAll('[data-image-stack]').forEach((stack) => {
				if (!(stack instanceof HTMLButtonElement)) return;

				const images = Array.from(stack.querySelectorAll('[data-stack-image]'));
				const count = stack.querySelector('[data-stack-count]');
				let activeIndex = 0;

				stack.addEventListener('click', () => {
					activeIndex = (activeIndex + 1) % images.length;

					images.forEach((image, imageIndex) => {
						if (image instanceof HTMLElement) {
							image.dataset.active = String(imageIndex === activeIndex);
						}
					});

					if (count) count.textContent = `${activeIndex + 1} / ${images.length}`;
				});
			});
		});
	};

	setupProjectIndexes();

	const portfolioWindow = window as Window & { __portfolioProjectIndexListener?: boolean };

	if (!portfolioWindow.__portfolioProjectIndexListener) {
		portfolioWindow.__portfolioProjectIndexListener = true;
		document.addEventListener('astro:page-load', setupProjectIndexes);
	}
</script>

<style>
	.project-detail {
		max-height: 0;
		opacity: 0;
		overflow: hidden;
		transition:
			max-height 640ms cubic-bezier(0.76, 0, 0.24, 1),
			opacity 260ms ease;
	}

	.project-item[data-open='true'] .project-detail {
		max-height: 54rem;
		opacity: 1;
	}

	.project-item[data-open='true'] .project-state {
		border-color: #171717;
		color: #171717;
	}

	.project-state::before {
		content: '+';
	}

	.project-item[data-open='true'] .project-state::before {
		content: '-';
	}

	.project-cover {
		position: relative;
		display: block;
		min-height: 20rem;
		overflow: hidden;
		border-right: 0;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.24), transparent 42%),
			linear-gradient(90deg, rgba(23, 23, 23, 0.08) 1px, transparent 1px),
			linear-gradient(0deg, rgba(23, 23, 23, 0.08) 1px, transparent 1px),
			#dfddd8;
		background-size:
			auto,
			64px 64px,
			64px 64px,
			auto;
	}

	.project-cover::before,
	.project-cover::after,
	.project-cover-frame,
	.project-cover-frame::before {
		content: '';
		position: absolute;
		pointer-events: none;
	}

	.project-cover::before {
		inset: 12% 18%;
		border: 1px solid rgba(23, 23, 23, 0.18);
		transform: skewY(-6deg);
	}

	.project-cover::after {
		right: 14%;
		bottom: 14%;
		width: 34%;
		height: 38%;
		border-top: 1px solid rgba(23, 23, 23, 0.25);
		border-left: 1px solid rgba(23, 23, 23, 0.18);
		transform: rotate(-7deg);
	}

	.project-cover-has-image::before,
	.project-cover-has-image::after {
		display: none;
	}

	.project-cover.project-cover-has-image {
		background: #fff;
	}

	.project-cover-frame {
		left: 18%;
		top: 18%;
		width: 26%;
		height: 54%;
		background: rgba(250, 250, 249, 0.38);
	}

	.project-cover-frame::before {
		inset: 18% -75% auto 45%;
		height: 1px;
		background: rgba(23, 23, 23, 0.22);
		transform: rotate(26deg);
		transform-origin: left center;
	}

	.project-cover-index {
		position: absolute;
		left: 1.25rem;
		top: 1.25rem;
		z-index: 1;
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.22em;
		color: rgba(23, 23, 23, 0.56);
	}

	.project-cover-image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.project-summary {
		position: relative;
		overflow: hidden;
	}

	.project-summary-has-image::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 1;
		background: linear-gradient(180deg, rgba(250, 250, 249, 0.38), rgba(250, 250, 249, 0.68));
		pointer-events: none;
	}

	.project-summary-image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.project-summary-content,
	.project-summary .project-state {
		position: relative;
		z-index: 2;
	}

	.project-cover-1 {
		background-color: #d7ddd6;
	}

	.project-cover-2 {
		background-color: #ded5cc;
	}

	.project-cover-3 {
		background-color: #d5dbe0;
	}

	.project-strip {
		scrollbar-color: #a8a29e transparent;
		scrollbar-width: thin;
		scroll-snap-type: x mandatory;
	}

	.project-image-frame {
		display: flex;
		height: clamp(28rem, 58vh, 42rem);
		align-items: center;
		justify-content: center;
		overflow: hidden;
		border: 1px solid rgba(23, 23, 23, 0.12);
		background: #fff;
	}

	.project-image {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.project-image-stack {
		position: relative;
		display: block;
		height: clamp(28rem, 58vh, 42rem);
		width: 100%;
		cursor: pointer;
		overflow: hidden;
		border: 1px solid rgba(23, 23, 23, 0.12);
		background: #fff;
		box-shadow:
			6px 6px 0 #f5f5f4,
			12px 12px 0 #e7e5e4;
	}

	.project-stack-image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: contain;
		opacity: 0;
		transition: opacity 300ms ease;
	}

	.project-stack-image[data-active='true'] {
		opacity: 1;
	}

	.project-stack-count {
		position: absolute;
		right: 1rem;
		bottom: 1rem;
		z-index: 1;
		padding: 0.4rem 0.65rem;
		background: rgba(250, 250, 249, 0.88);
		font-size: 0.62rem;
		font-weight: 500;
		letter-spacing: 0.16em;
		color: #525252;
	}

	.project-mock-image {
		--surface: #dedbd5;
		--line: rgba(23, 23, 23, 0.2);
		--accent: rgba(86, 97, 88, 0.36);
		position: relative;
		aspect-ratio: 16 / 10;
		min-height: 22rem;
		overflow: hidden;
		border: 1px solid rgba(23, 23, 23, 0.12);
		background:
			radial-gradient(circle at 72% 24%, rgba(255, 255, 255, 0.45), transparent 24%),
			linear-gradient(90deg, var(--line) 1px, transparent 1px),
			linear-gradient(0deg, var(--line) 1px, transparent 1px),
			var(--surface);
		background-size:
			auto,
			58px 58px,
			58px 58px,
			auto;
	}

	.project-mock-image::before,
	.project-mock-image::after,
	.project-mock-image span,
	.project-mock-image span::before {
		content: '';
		position: absolute;
		pointer-events: none;
	}

	.project-mock-image::before {
		left: 12%;
		top: 16%;
		width: 54%;
		height: 54%;
		border: 1px solid var(--line);
		background: rgba(250, 250, 249, 0.26);
		transform: perspective(34rem) rotateY(24deg) rotateZ(-4deg);
	}

	.project-mock-image::after {
		right: 12%;
		bottom: 16%;
		width: 40%;
		height: 1px;
		background: var(--line);
		transform: rotate(-18deg);
		transform-origin: right center;
	}

	.project-mock-image span {
		left: 20%;
		bottom: 18%;
		width: 42%;
		height: 30%;
		border-left: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		background: var(--accent);
		clip-path: polygon(0 28%, 100% 0, 100% 72%, 0 100%);
	}

	.project-mock-image span::before {
		left: 72%;
		top: -58%;
		width: 1px;
		height: 120%;
		background: var(--line);
		transform: rotate(36deg);
	}

	.tone-sage {
		--surface: #d9dfd7;
		--accent: rgba(83, 103, 91, 0.34);
	}

	.tone-clay {
		--surface: #ded2ca;
		--accent: rgba(138, 90, 66, 0.28);
	}

	.tone-steel {
		--surface: #d8dde1;
		--accent: rgba(72, 91, 104, 0.3);
	}

	@media (max-width: 767px) {
		.project-item[data-open='true'] .project-detail {
			max-height: 48rem;
		}

		.project-mock-image {
			min-height: 18rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.project-detail {
			transition: none;
		}
	}
</style>
